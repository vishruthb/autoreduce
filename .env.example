# --- Credentials (planner + agents call Claude). Required for a real run. ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Models ---
AUTOREDUCE_MODEL=claude-opus-4-8          # planner
AUTOREDUCE_AGENT_MODEL=claude-sonnet-4-6  # the 8 worker agents (Claude Agent SDK)

# --- Task + run ---
# Tasks are EXTERNAL (the package ships no domains). They live under this dir and
# are loaded by folder name; the bundled example is examples/specdec.
AUTOREDUCE_TASKS_DIR=examples
# AUTOREDUCE_TASK=specdec                   # default task; else the first one found
AUTOREDUCE_POOL_SIZE=8
AUTOREDUCE_DEFAULT_BUDGET=40               # completed methods before a run halts

# --- Agent session limits ---
AUTOREDUCE_AGENT_TIMEOUT=180               # per-idea wall-clock (seconds)
AUTOREDUCE_AGENT_MAX_TURNS=24
AUTOREDUCE_AGENT_MAX_BUDGET_USD=0.50       # per-agent-session cost cap

# --- Control plane ---
AUTOREDUCE_HOST=127.0.0.1
AUTOREDUCE_PORT=8000
AUTOREDUCE_DB=autoreduce.db
AUTOREDUCE_SEED=1234
AUTOREDUCE_HEARTBEAT_TIMEOUT=8

# --- Key-free / CLI-free demo: a deterministic fake agent ---
# AUTOREDUCE_FAKE_AGENT=1

# --- Frontend (web/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
